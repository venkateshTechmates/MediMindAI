# ── MediMind AI Environment Variables ──
# Copy this file to .env and fill in the values.

# ── SQL Server ──
ConnectionStrings__DefaultConnection=Server=localhost,1433;Database=MediMindAI;User Id=sa;Password=Your_Strong_Password_123;TrustServerCertificate=True;MultipleActiveResultSets=true

# ── Redis ──
ConnectionStrings__Redis=localhost:6379

# ── Qdrant ──
Qdrant__Host=localhost
Qdrant__Port=6334

# ── Anthropic Claude ──
Anthropic__ApiKey=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
Anthropic__Model=claude-sonnet-4-20250514
Anthropic__MaxTokens=4096
Anthropic__UseMock=true

# ── Blazor UI ──
BlazorUI__BaseUrl=https://localhost:5002

# ── ASP.NET Core ──
ASPNETCORE_ENVIRONMENT=Development
